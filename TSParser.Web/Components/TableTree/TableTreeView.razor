@using TSParser.Web.Models

<div class="table-tree" role="tree" aria-label="PIDs and SI tables">
    @if (Categories.Count == 0)
    {
        <p class="table-tree-empty">No tables yet. Open a file or start UDP to parse.</p>
    }
    else
    {
        <ul class="table-tree-root">
            @foreach (var category in Categories)
            {
                <TableTreeNodeView Node="category"
                                   Store="Store"
                                   SelectedNodeId="SelectedNodeId"
                                   OnSelect="OnSelect"
                                   OnToggleExpand="OnToggleExpand" />
            }
        </ul>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public TableVersionStore Store { get; set; } = null!;

    [Parameter]
    public Guid? SelectedNodeId { get; set; }

    [Parameter]
    public EventCallback<TableTreeNode> OnSelect { get; set; }

    [Parameter]
    public EventCallback OnStructureChanged { get; set; }

    private IReadOnlyList<TableTreeNode> Categories => Store.RootCategories;

    private async Task OnToggleExpand((TableTreeNode Node, bool Expanded) args)
    {
        // #region agent log
        try
        {
            var line = System.Text.Json.JsonSerializer.Serialize(new
            {
                sessionId = "93273f",
                hypothesisId = "D",
                location = "TableTreeView.OnToggleExpand",
                message = "UI toggle",
                data = new
                {
                    args.Node.Id,
                    args.Node.Label,
                    kind = args.Node.Kind.ToString(),
                    args.Expanded
                },
                timestamp = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()
            });
            System.IO.File.AppendAllText(
                Path.Combine(AppContext.BaseDirectory, "..", "..", "..", "..", "debug-93273f.log"),
                line + Environment.NewLine);
        }
        catch
        {
        }
        // #endregion

        Store.SetExpanded(args.Node.Id, args.Expanded);
        await OnStructureChanged.InvokeAsync();
    }
}
