@rendermode InteractiveServer

@using TSParser.Analysis
@using Microsoft.AspNetCore.Components.Forms
@inject TsParserSessionService Session
@inject BitrateHistoryStore BitrateStore
@inject NetworkInterfaceService NetworkInterfaces

<header class="parser-toolbar">
    <span class="parser-brand">TSParser</span>

    <div class="toolbar-groups">
        <div class="toolbar-group">
            <label class="toolbar-btn toolbar-btn--file @(_sessionBusy ? "toolbar-btn--busy" : null)"
                   title="Open transport stream file">
                File…
                <InputFile OnChange="OnTransportStreamFileSelected"
                           accept=".ts,.m2ts,.mpg,.mpeg,video/mp2t"
                           class="toolbar-file-input"
                           disabled="@_sessionBusy" />
            </label>
            <button type="button" class="toolbar-btn" @onclick="ShowBitrateDialog">Bitrate…</button>
        </div>

        <div class="toolbar-group toolbar-group--udp">
            <label class="toolbar-label" for="multicast-endpoint">Multicast</label>
            <input id="multicast-endpoint"
                   class="toolbar-input toolbar-input--endpoint"
                   @bind="_multicastEndpoint"
                   @bind:event="oninput"
                   placeholder="239.1.2.3:1234"
                   disabled="@IsUdpRunning"
                   autocomplete="off" />

            <label class="toolbar-label" for="bind-address">Source IP</label>
            <select id="bind-address"
                    class="toolbar-select"
                    @bind="_selectedBindAddress"
                    disabled="@IsUdpRunning">
                @foreach (var opt in _bindOptions)
                {
                    <option value="@(opt.Address ?? "")">@opt.Label</option>
                }
            </select>

            <button type="button"
                    class="toolbar-btn toolbar-btn--primary"
                    @onclick="PlayUdpAsync"
                    disabled="@(_sessionBusy || IsUdpRunning || !CanPlayUdp)">
                Play
            </button>
            <button type="button"
                    class="toolbar-btn"
                    @onclick="StopUdp"
                    disabled="@(!IsUdpRunning)">
                Stop
            </button>
        </div>

        <div class="toolbar-group">
            <button type="button" class="toolbar-btn" @onclick="ShowEwsDialog" disabled="@_sessionBusy">EWS…</button>
        </div>
    </div>

    <span class="parser-status" title="@StatusDisplay">@StatusDisplay</span>
</header>

@if (_showBitrateDialog)
{
    <div class="toolbar-modal-backdrop" @onclick="CloseBitrateDialog">
        <div class="toolbar-modal toolbar-modal--bitrate" role="dialog" aria-labelledby="bitrate-dialog-title" @onclick:stopPropagation="true">
            <h2 id="bitrate-dialog-title" class="toolbar-modal-title">Bitrate</h2>
            <p class="toolbar-modal-hint">Changing measurement options or selected PIDs restarts the current file or UDP session when one is open. Chart display options (stream / sum lines) update immediately.</p>

            <h3 class="toolbar-section-title">Measurement</h3>

            <div class="toolbar-form-grid">
                <label for="clock-source">Clock source</label>
                <select id="clock-source" class="toolbar-select" @bind="_bitrateClockSource">
                    <option value="@BitrateClockSource.Pcr">PCR</option>
                    <option value="@BitrateClockSource.Pts">PTS</option>
                    <option value="@BitrateClockSource.Dts">DTS</option>
                    <option value="@BitrateClockSource.AssumedTransportRate">Assumed transport rate</option>
                </select>

                <label for="measurement-window">Window (seconds)</label>
                <input id="measurement-window" class="toolbar-input" type="number" min="0.1" step="0.1" @bind="_measurementWindowSeconds" />

                <label for="reference-pid">Reference PID</label>
                <input id="reference-pid" class="toolbar-input" @bind="_referencePidText" placeholder="optional, e.g. 0x0100" />

                @if (_bitrateClockSource == BitrateClockSource.AssumedTransportRate)
                {
                    <label for="assumed-bps">Assumed rate (Mb/s)</label>
                    <input id="assumed-bps" class="toolbar-input" type="number" min="0.1" step="0.1" @bind="_assumedMbps" />
                }

                <span class="toolbar-form-span"></span>
                <div class="toolbar-checks">
                    <label class="toolbar-check">
                        <input type="checkbox" @bind="_measureStreamBitrate" />
                        Measure stream bitrate
                    </label>
                    <label class="toolbar-check">
                        <input type="checkbox" @bind="_measureUsefulAndTotal" />
                        Total + useful (exclude null PID)
                    </label>
                </div>
            </div>

            <h3 class="toolbar-section-title">Chart</h3>
            <div class="toolbar-checks toolbar-checks--inline">
                <label class="toolbar-check">
                    <input type="checkbox" @bind="_showStreamOnChart" />
                    Stream (total / useful)
                </label>
                <label class="toolbar-check" title="Sum of selected PID bitrates at each window">
                    <input type="checkbox" @bind="_showPidSumOnChart" disabled="@(_chartSelectedPids.Count < 2)" />
                    Sum of selected PIDs
                </label>
                <label class="toolbar-check" title="Separate line per selected PID">
                    <input type="checkbox" @bind="_showIndividualPidsOnChart" disabled="@(_chartSelectedPids.Count == 0)" />
                    Per-PID lines
                </label>
            </div>

            <div class="toolbar-pid-picker-header">
                <span class="toolbar-pid-picker-label">PIDs in stream</span>
                <div class="toolbar-pid-picker-actions">
                    <button type="button" class="toolbar-btn toolbar-btn--small" @onclick="RefreshObservedPids" disabled="@(_availablePids.Count == 0)">Refresh</button>
                    <button type="button" class="toolbar-btn toolbar-btn--small" @onclick="SelectAllChartPids" disabled="@(_availablePids.Count == 0)">All</button>
                    <button type="button" class="toolbar-btn toolbar-btn--small" @onclick="ClearChartPids" disabled="@(_chartSelectedPids.Count == 0)">Clear</button>
                </div>
            </div>

            @if (_availablePids.Count == 0)
            {
                <p class="toolbar-modal-hint toolbar-pid-picker-empty">No PIDs observed yet. Open a file or start UDP, then refresh this list.</p>
            }
            else
            {
                <div class="toolbar-pid-picker" role="group" aria-label="PIDs to chart">
                    @foreach (var pid in _availablePids)
                    {
                        <label class="toolbar-pid-item">
                            <input type="checkbox"
                                   checked="@_chartSelectedPids.Contains(pid)"
                                   @onchange="e => OnChartPidToggled(pid, e)" />
                            <span>0x@(pid.ToString("X4"))</span>
                        </label>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(_bitrateError))
            {
                <p class="toolbar-modal-error">@_bitrateError</p>
            }

            <div class="toolbar-modal-actions">
                <button type="button" class="toolbar-btn toolbar-btn--primary" @onclick="SaveBitrateSettings">OK</button>
                <button type="button" class="toolbar-btn" @onclick="CloseBitrateDialog">Cancel</button>
            </div>
        </div>
    </div>
}

@if (_showEwsDialog)
{
    <div class="toolbar-modal-backdrop" @onclick="CloseEwsDialog">
        <div class="toolbar-modal toolbar-modal--wide" role="dialog" aria-labelledby="ews-dialog-title" @onclick:stopPropagation="true">
            <h2 id="ews-dialog-title" class="toolbar-modal-title">EWS / EEWS PIDs</h2>
            <p class="toolbar-modal-hint">
                Operator EWS and EEWS tables appear only when the parser is given their PIDs before play.
                Comma-separated decimal or hex (for example 0x1A00, 0x1A01).
            </p>

            <label class="toolbar-field-label" for="ews-pids">EWS PIDs</label>
            <input id="ews-pids" class="toolbar-input toolbar-input--wide" @bind="_ewsPidsText" placeholder="0x1A00" />

            <label class="toolbar-field-label" for="eews-pids">EEWS PIDs</label>
            <input id="eews-pids" class="toolbar-input toolbar-input--wide" @bind="_eewsPidsText" placeholder="0x1A01" />

            @if (!string.IsNullOrEmpty(_ewsError))
            {
                <p class="toolbar-modal-error">@_ewsError</p>
            }

            <div class="toolbar-modal-actions">
                <button type="button" class="toolbar-btn toolbar-btn--primary" @onclick="SaveEwsSettings">OK</button>
                <button type="button" class="toolbar-btn" @onclick="CloseEwsDialog">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string StatusText { get; set; } = "Idle";

    [Parameter]
    public EventCallback OnChartSettingsChanged { get; set; }

    private IReadOnlyList<NetworkInterfaceService.BindOption> _bindOptions = [];
    private string _multicastEndpoint = "239.1.2.3:1234";
    private string _selectedBindAddress = "";
    private bool _showBitrateDialog;
    private bool _showEwsDialog;
    private bool _sessionBusy;
    private string? _bitrateError;
    private string? _ewsError;
    private string? _sessionError;

    private BitrateClockSource _bitrateClockSource;
    private double _measurementWindowSeconds = 1;
    private string _referencePidText = "";
    private double _assumedMbps = 10;
    private bool _measureStreamBitrate = true;
    private bool _measureUsefulAndTotal = true;
    private bool _showStreamOnChart = true;
    private bool _showPidSumOnChart = true;
    private bool _showIndividualPidsOnChart = true;
    private readonly HashSet<ushort> _chartSelectedPids = [];
    private List<ushort> _availablePids = [];
    private BitrateMeasurementSnapshot _bitrateMeasurementBaseline;

    private string _ewsPidsText = "";
    private string _eewsPidsText = "";

    private string StatusDisplay =>
        !string.IsNullOrEmpty(_sessionError) ? _sessionError : StatusText;

    private bool IsUdpRunning => Session.InputMode == TsParserSessionInputMode.Udp && Session.IsRunning;

    private bool CanPlayUdp => TsParserSessionService.TryParseMulticastEndpoint(_multicastEndpoint, out _, out _);

    protected override void OnInitialized()
    {
        _bindOptions = NetworkInterfaces.GetBindOptions();
        LoadSettingsFromSession();
    }

    private void LoadSettingsFromSession()
    {
        var s = Session.Settings;
        _bitrateClockSource = s.ClockSource;
        _measurementWindowSeconds = s.MeasurementWindow.TotalSeconds;
        _referencePidText = s.ReferencePid is { } refPid ? $"0x{refPid:X4}" : "";
        _assumedMbps = s.AssumedBitsPerSecond / 1_000_000d;
        _measureStreamBitrate = s.MeasureStreamBitrate;
        _measureUsefulAndTotal = s.MeasureUsefulAndTotalBitrate;
        _showStreamOnChart = s.ShowStreamOnChart;
        _showPidSumOnChart = s.ShowPidSumOnChart;
        _showIndividualPidsOnChart = s.ShowIndividualPidsOnChart;
        _chartSelectedPids.Clear();
        foreach (var pid in s.ChartPids)
            _chartSelectedPids.Add(pid);

        RefreshObservedPids();
        _ewsPidsText = FormatPidList(s.EwsPids);
        _eewsPidsText = FormatPidList(s.EewsPids);

        if (!string.IsNullOrEmpty(Session.CurrentMulticastEndpoint))
            _multicastEndpoint = Session.CurrentMulticastEndpoint;

        _selectedBindAddress = Session.CurrentBindAddress ?? "";
    }

    private static string FormatPidList(IReadOnlyList<ushort> pids) =>
        pids.Count == 0 ? "" : string.Join(", ", pids.Select(p => $"0x{p:X4}"));

    private async Task OnTransportStreamFileSelected(InputFileChangeEventArgs e)
    {
        if (_sessionBusy)
            return;

        var file = e.File;
        if (file is null)
            return;

        _sessionError = null;
        _sessionBusy = true;

        try
        {
            await Session.OpenUploadedFileAsync(file);
        }
        catch (Exception ex)
        {
            _sessionError = ex.Message;
        }
        finally
        {
            _sessionBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ShowBitrateDialog()
    {
        _bitrateError = null;
        LoadSettingsFromSession();
        _bitrateMeasurementBaseline = BitrateMeasurementSnapshot.From(Session.Settings);
        _showBitrateDialog = true;
    }

    private void RefreshObservedPids()
    {
        if (Session.TryGetObservedPids(out var pids))
            _availablePids = pids.OrderBy(p => p).ToList();
        else
            _availablePids = [];

        var available = _availablePids.ToHashSet();
        _chartSelectedPids.RemoveWhere(p => !available.Contains(p));
    }

    private void OnChartPidToggled(ushort pid, ChangeEventArgs e)
    {
        if (e.Value is bool selected)
        {
            if (selected)
                _chartSelectedPids.Add(pid);
            else
                _chartSelectedPids.Remove(pid);
        }
    }

    private void SelectAllChartPids()
    {
        foreach (var pid in _availablePids)
            _chartSelectedPids.Add(pid);
    }

    private void ClearChartPids() => _chartSelectedPids.Clear();

    private void CloseBitrateDialog() => _showBitrateDialog = false;

    private void ShowEwsDialog()
    {
        _ewsError = null;
        LoadSettingsFromSession();
        _showEwsDialog = true;
    }

    private void CloseEwsDialog() => _showEwsDialog = false;

    private void SaveBitrateSettings()
    {
        _bitrateError = null;

        if (_measurementWindowSeconds <= 0)
        {
            _bitrateError = "Measurement window must be greater than zero.";
            return;
        }

        ushort? referencePid = null;
        if (!string.IsNullOrWhiteSpace(_referencePidText))
        {
            if (!TsPidListParser.TryParsePid(_referencePidText, out var pid))
            {
                _bitrateError = "Reference PID is invalid.";
                return;
            }

            referencePid = pid;
        }

        if (_assumedMbps <= 0)
        {
            _bitrateError = "Assumed rate must be greater than zero.";
            return;
        }

        if (!_showStreamOnChart && _chartSelectedPids.Count == 0)
        {
            _bitrateError = "Select stream and/or at least one PID for the chart.";
            return;
        }

        if (!_showStreamOnChart && !_showIndividualPidsOnChart && (!_showPidSumOnChart || _chartSelectedPids.Count < 2))
        {
            _bitrateError = "Enable Stream, Per-PID lines, or Sum of selected PIDs (needs 2+ PIDs).";
            return;
        }

        if (_chartSelectedPids.Count > 0 && _availablePids.Count > 0)
        {
            var unknown = _chartSelectedPids.Where(p => !_availablePids.Contains(p)).ToList();
            if (unknown.Count > 0)
            {
                _bitrateError = $"PID(s) not in stream: {string.Join(", ", unknown.Select(p => $"0x{p:X4}"))}.";
                return;
            }
        }

        var chartPids = _chartSelectedPids.OrderBy(p => p).ToList();
        var settings = Session.Settings;
        settings.ClockSource = _bitrateClockSource;
        settings.MeasurementWindow = TimeSpan.FromSeconds(_measurementWindowSeconds);
        settings.ReferencePid = referencePid;
        settings.AssumedBitsPerSecond = _assumedMbps * 1_000_000d;
        settings.MeasureStreamBitrate = _measureStreamBitrate;
        settings.MeasureUsefulAndTotalBitrate = _measureUsefulAndTotal;
        settings.ShowStreamOnChart = _showStreamOnChart;
        settings.ShowPidSumOnChart = _showPidSumOnChart && chartPids.Count >= 2;
        settings.ShowIndividualPidsOnChart = _showIndividualPidsOnChart && chartPids.Count > 0;
        settings.SetChartPids(chartPids);
        settings.ApplyChartTo(BitrateStore);

        var needsParserRestart = Session.HasActiveSource
            && BitrateMeasurementSnapshot.From(settings).RequiresParserRestart(_bitrateMeasurementBaseline);

        _showBitrateDialog = false;

        if (needsParserRestart)
            _ = RestartParserForBitrateSettingsAsync();
        else
            _ = OnChartSettingsChanged.InvokeAsync();
    }

    private async Task RestartParserForBitrateSettingsAsync()
    {
        _sessionError = null;
        _sessionBusy = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Session.RestartCurrentSessionAsync();
        }
        catch (Exception ex)
        {
            _sessionError = ex.Message;
        }
        finally
        {
            _sessionBusy = false;
            await OnChartSettingsChanged.InvokeAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private void SaveEwsSettings()
    {
        _ewsError = null;

        if (!TsPidListParser.TryParseList(_ewsPidsText, out var ews, out var err))
        {
            _ewsError = $"EWS: {err}";
            return;
        }

        if (!TsPidListParser.TryParseList(_eewsPidsText, out var eews, out err))
        {
            _ewsError = $"EEWS: {err}";
            return;
        }

        Session.Settings.SetEwsPids(ews);
        Session.Settings.SetEewsPids(eews);
        _showEwsDialog = false;
    }

    private void PlayUdpAsync()
    {
        if (!CanPlayUdp || _sessionBusy)
            return;

        _sessionError = null;
        var bind = string.IsNullOrEmpty(_selectedBindAddress) ? null : _selectedBindAddress;
        var endpoint = _multicastEndpoint.Trim();
        _ = RunSessionInBackgroundAsync(
            () => Session.StartUdpAsync(endpoint, bind),
            ex => _sessionError = ex.Message);
    }

    private void StopUdp()
    {
        _sessionError = null;
        Session.Stop();
    }

    private Task RunSessionInBackgroundAsync(Func<Task> start, Action<Exception>? onError = null)
    {
        if (_sessionBusy)
            return Task.CompletedTask;

        _sessionBusy = true;
        _ = InvokeAsync(StateHasChanged);

        return Task.Run(async () =>
        {
            try
            {
                await start().ConfigureAwait(false);
            }
            catch (Exception ex)
            {
                await InvokeAsync(() =>
                {
                    onError?.Invoke(ex);
                    if (onError is null)
                        _sessionError = ex.Message;
                }).ConfigureAwait(false);
            }
            finally
            {
                await InvokeAsync(() =>
                {
                    _sessionBusy = false;
                    StateHasChanged();
                }).ConfigureAwait(false);
            }
        });
    }
}
