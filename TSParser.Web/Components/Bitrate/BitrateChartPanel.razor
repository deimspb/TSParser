@using System.Text.Json
@using ScottPlot
@using TSParser.Web.Services
@inject IWebHostEnvironment WebHostEnvironment
@inject IJSRuntime Js

<div class="bitrate-chart-panel">
    <div class="bitrate-chart-header">
        <span class="bitrate-chart-title">Transport bitrate</span>
        <span class="bitrate-chart-stats">@_statsText</span>
    </div>

    <div class="bitrate-chart-plot-wrap" @ref="_wrapRef">
        @if (_hasData && !string.IsNullOrEmpty(_chartImageUri))
        {
            <img class="bitrate-chart-plot"
                 src="@_chartImageUri"
                 data-revision="@_renderedRevision"
                 alt="Transport bitrate chart" />
        }
        else if (_hasData)
        {
            <p class="bitrate-chart-placeholder">@_placeholderText</p>
        }
        else
        {
            <p class="bitrate-chart-placeholder">@_placeholderText</p>
        }
    </div>
</div>

@code {
    private const int MinChartWidth = 320;
    private const int MinChartHeight = 100;
    private const int DefaultChartWidth = 800;
    private const int DefaultChartHeight = 180;

    private ElementReference _wrapRef;
    private int _renderedRevision = -1;
    private int _renderedWidth;
    private int _renderedHeight;
    private bool _hasData;
    private string? _chartImageUri;
    private string _statsText = "";
    private string _placeholderText = "Bitrate samples appear while parsing a file or UDP stream.";

    [Parameter]
    public BitrateHistoryStore Store { get; set; } = null!;

    [Parameter]
    public int DataRevision { get; set; }

    protected override void OnParametersSet()
    {
        var snapshot = Store.GetSnapshot();
        _hasData = snapshot.Mode switch
        {
            BitrateChartMode.File => snapshot.FilePoints.Count > 0,
            BitrateChartMode.Udp => snapshot.UdpPoints.Count > 0,
            _ => false
        };

        _placeholderText = snapshot.Mode switch
        {
            BitrateChartMode.File when _hasData => "Rendering bitrate chart…",
            BitrateChartMode.File => "Waiting for bitrate windows during file parse…",
            BitrateChartMode.Udp when _hasData => "Rendering live bitrate chart…",
            BitrateChartMode.Udp => "Waiting for live bitrate samples…",
            _ => "Bitrate samples appear while parsing a file or UDP stream."
        };

        _statsText = BuildStatsText(snapshot);

        if (!_hasData)
        {
            _chartImageUri = null;
            _renderedRevision = -1;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_hasData)
            return;

        try
        {
            var size = await Js.InvokeAsync<PlotWrapSize>("bitrateChart.getPlotWrapSize", _wrapRef);
            var width = size.Width >= MinChartWidth ? size.Width : DefaultChartWidth;
            var height = size.Height >= MinChartHeight ? size.Height : DefaultChartHeight;

            var sizeChanged = Math.Abs(width - _renderedWidth) > 8 || Math.Abs(height - _renderedHeight) > 8;
            var dataChanged = DataRevision != _renderedRevision;

            if (dataChanged || sizeChanged || string.IsNullOrEmpty(_chartImageUri))
            {
                var snapshot = Store.GetSnapshot();
                var plot = new Plot();
                if (!TryApplySnapshot(plot, snapshot))
                    return;

                plot.ShowLegend(Alignment.UpperRight);
                plot.Axes.AutoScale();

                var bytes = plot.GetImageBytes(width, height, ImageFormat.Png);
                _chartImageUri = $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
                _renderedRevision = DataRevision;
                _renderedWidth = width;
                _renderedHeight = height;

                // #region agent log
                AgentDebugLog("F", "BitrateChartPanel.razor:OnAfterRenderAsync", "Server PNG chart rendered", new
                {
                    renderMode = "server-png-dynamic-zoom",
                    chartWidth = width,
                    chartHeight = height,
                    pngBytes = bytes.Length,
                    dataRevision = DataRevision,
                    pointCount = snapshot.Mode == BitrateChartMode.File ? snapshot.FilePoints.Count : snapshot.UdpPoints.Count
                });
                // #endregion

                StateHasChanged();
                return;
            }

            await Js.InvokeVoidAsync("bitrateChart.attachZoom", _wrapRef);
            // #region agent log
            await Js.InvokeVoidAsync("bitrateChart.logDom");
            // #endregion
        }
        catch (Exception ex)
        {
            _chartImageUri = null;
            _placeholderText = "Chart render failed.";
            // #region agent log
            AgentDebugLog("F", "BitrateChartPanel.razor:OnAfterRenderAsync", "Chart render failed", new { ex.Message });
            // #endregion
        }
    }

    // #region agent log
    private void AgentDebugLog(string hypothesisId, string location, string message, object data)
    {
        try
        {
            var logPath = Path.GetFullPath(Path.Combine(WebHostEnvironment.ContentRootPath, "..", "debug-64f5ce.log"));
            var payload = new Dictionary<string, object?>
            {
                ["sessionId"] = "64f5ce",
                ["runId"] = "post-fix",
                ["hypothesisId"] = hypothesisId,
                ["location"] = location,
                ["message"] = message,
                ["data"] = data,
                ["timestamp"] = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()
            };
            File.AppendAllText(logPath, JsonSerializer.Serialize(payload) + Environment.NewLine);
        }
        catch
        {
            // ignore debug log failures
        }
    }

    private sealed record PlotWrapSize(int Width, int Height);
    // #endregion

    private static string BuildStatsText(BitrateChartSnapshot snapshot)
    {
        if (snapshot.Mode == BitrateChartMode.File && snapshot.FilePoints.Count > 0)
        {
            var avgTotal = snapshot.AverageTotalMegabitsPerSecond;
            var avgUseful = snapshot.AverageUsefulMegabitsPerSecond;
            if (avgTotal.HasValue && avgUseful.HasValue)
                return $"Avg total {avgTotal.Value:F2} Mbps · useful {avgUseful.Value:F2} Mbps · {snapshot.FilePoints.Count} windows";
        }

        if (snapshot.Mode == BitrateChartMode.Udp && snapshot.UdpPoints.Count > 0)
        {
            var latest = snapshot.UdpPoints[^1];
            return $"Live {latest.TotalBitsPerSecond / 1_000_000d:F2} / {latest.UsefulBitsPerSecond / 1_000_000d:F2} Mbps (total / useful)";
        }

        return "";
    }

    private static bool TryApplySnapshot(Plot plot, BitrateChartSnapshot snapshot)
    {
        plot.Clear();

        switch (snapshot.Mode)
        {
            case BitrateChartMode.File when snapshot.FilePoints.Count > 0:
                RenderFileSeries(plot, snapshot);
                return true;

            case BitrateChartMode.Udp when snapshot.UdpPoints.Count > 0:
                RenderUdpSeries(plot, snapshot);
                return true;

            default:
                return false;
        }
    }

    private static void RenderFileSeries(Plot plot, BitrateChartSnapshot snapshot)
    {
        var usePercent = snapshot.FileLengthBytes is > 0;
        var xs = new double[snapshot.FilePoints.Count];
        var totalYs = new double[snapshot.FilePoints.Count];
        var usefulYs = new double[snapshot.FilePoints.Count];

        for (var i = 0; i < snapshot.FilePoints.Count; i++)
        {
            var point = snapshot.FilePoints[i];
            xs[i] = usePercent
                ? 100d * point.ByteOffset / snapshot.FileLengthBytes!.Value
                : point.ByteOffset / 1_000_000d;

            totalYs[i] = point.TotalBitsPerSecond / 1_000_000d;
            usefulYs[i] = point.UsefulBitsPerSecond / 1_000_000d;
        }

        var total = plot.Add.Scatter(xs, totalYs);
        total.LegendText = "Total";
        total.Color = Colors.SteelBlue;
        total.LineWidth = 2;
        total.MarkerSize = 0;

        var useful = plot.Add.Scatter(xs, usefulYs);
        useful.LegendText = "Useful";
        useful.Color = Colors.ForestGreen;
        useful.LineWidth = 2;
        useful.MarkerSize = 0;

        plot.Axes.Bottom.Label.Text = usePercent ? "File position (%)" : "File offset (MB)";
        plot.Axes.Left.Label.Text = "Mbps";
        plot.Title(usePercent ? "Bitrate vs file position" : "Bitrate vs byte offset");
    }

    private static void RenderUdpSeries(Plot plot, BitrateChartSnapshot snapshot)
    {
        var points = snapshot.UdpPoints;
        var origin = points[0].TimestampUtc;
        var xs = new double[points.Count];
        var totalYs = new double[points.Count];
        var usefulYs = new double[points.Count];

        for (var i = 0; i < points.Count; i++)
        {
            xs[i] = (points[i].TimestampUtc - origin).TotalSeconds;
            totalYs[i] = points[i].TotalBitsPerSecond / 1_000_000d;
            usefulYs[i] = points[i].UsefulBitsPerSecond / 1_000_000d;
        }

        var total = plot.Add.Scatter(xs, totalYs);
        total.LegendText = "Total";
        total.Color = Colors.SteelBlue;
        total.LineWidth = 2;
        total.MarkerSize = 0;

        var useful = plot.Add.Scatter(xs, usefulYs);
        useful.LegendText = "Useful";
        useful.Color = Colors.ForestGreen;
        useful.LineWidth = 2;
        useful.MarkerSize = 0;

        plot.Axes.Bottom.Label.Text = "Time (s)";
        plot.Axes.Left.Label.Text = "Mbps";
        plot.Title("Live transport bitrate");
    }
}
