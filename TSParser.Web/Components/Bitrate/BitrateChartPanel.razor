@using Plotly.Blazor
@using Plotly.Blazor.ConfigLib
@using Plotly.Blazor.Traces
@using Plotly.Blazor.Traces.ScatterLib
@using Plotly.Blazor.LayoutLib
@using TSParser.Web.Services
@inject IJSRuntime Js

<div class="bitrate-chart-panel">
    <div class="bitrate-chart-header">
        <span class="bitrate-chart-title">@_chartTitle</span>
        <span class="bitrate-chart-stats">@_statsText</span>
    </div>

    <div class="bitrate-chart-plot-wrap">
        @if (_hasData)
        {
            <div class="bitrate-chart-plot">
                <PlotlyChart @ref="_chart"
                             Data="_data"
                             Layout="_layout"
                             Config="_config" />
            </div>
        }
        else
        {
            <p class="bitrate-chart-placeholder">@_placeholderText</p>
        }
    </div>
</div>

@code {
    private const double YAxisPaddingRatio = 0.12;
    private const double MinYAxisPaddingMbps = 0.5;
    private const double XAxisPaddingRatio = 0.02;
    private const double MinXAxisPadding = 0.25;

    private PlotlyChart? _chart;
    private Config _config = new() { Responsive = true, ScrollZoom = ScrollZoomFlag.Cartesian };
    private Layout _layout = new() { AutoSize = true };
    private IList<ITrace> _data = new List<ITrace>();
    private int _appliedRevision = -1;
    private int _appliedConfigRevision = -1;
    private int _appliedFitRevision = -1;
    private int _lastFitRevisionSeen = -1;
    private bool _needsStructureRedraw;
    private bool _hasData;
    private double _xMin;
    private double _xMax;
    private double _yMin;
    private double _yMax;
    private string _chartTitle = "Bitrate";
    private string _statsText = "";
    private string _placeholderText = "Open Bitrate… to choose stream and/or PID traces, then parse a file or UDP stream.";

    [Parameter]
    public BitrateHistoryStore Store { get; set; } = null!;

    [Parameter]
    public int DataRevision { get; set; }

    [Parameter]
    public int ChartConfigRevision { get; set; }

    [Parameter]
    public int FitRevision { get; set; }

    protected override void OnParametersSet()
    {
        var snapshot = Store.GetSnapshot();
        _hasData = snapshot.HasChartData;

        _placeholderText = BuildPlaceholderText(snapshot, _hasData);

        _chartTitle = BuildChartTitle(snapshot);
        _statsText = BuildStatsText(snapshot);

        if (!_hasData)
        {
            _appliedRevision = -1;
            _data = new List<ITrace>();
            return;
        }

        var fitChanged = FitRevision != _lastFitRevisionSeen;
        _lastFitRevisionSeen = FitRevision;

        var configChanged = ChartConfigRevision != _appliedConfigRevision;
        if (!fitChanged && !configChanged && DataRevision == _appliedRevision)
            return;

        _appliedRevision = DataRevision;
        if (configChanged)
            _needsStructureRedraw = true;

        _appliedConfigRevision = ChartConfigRevision;
        ApplySnapshot(snapshot);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_chart is null || !_hasData)
            return;

        try
        {
            var needsFit = FitRevision != _appliedFitRevision;
            if (needsFit || _needsStructureRedraw)
            {
                _appliedFitRevision = FitRevision;
                _needsStructureRedraw = false;
                await _chart.NewPlot();
            }
            else
            {
                await _chart.React();
            }

            await ApplyAxisRangesAsync();
        }
        catch
        {
            // chart may not be initialized on first paint yet
        }
    }

    private async Task ApplyAxisRangesAsync()
    {
        try
        {
            await Js.InvokeAsync<bool>(
                "tsParserPlotly.applyAxisRanges", _xMin, _xMax, _yMin, _yMax);
        }
        catch
        {
            // fall through to C# relayout
        }

        if (_chart is not null)
        {
            await _chart.Relayout(new
            {
                xaxis = new { range = new[] { _xMin, _xMax }, autorange = false },
                yaxis = new { range = new[] { _yMin, _yMax }, autorange = false }
            });
        }
    }

    private void ApplySnapshot(BitrateChartSnapshot snapshot)
    {
        switch (snapshot.Mode)
        {
            case BitrateChartMode.File when snapshot.HasChartData:
                BuildFileChart(snapshot);
                break;
            case BitrateChartMode.Udp when snapshot.HasChartData:
                BuildUdpChart(snapshot);
                break;
        }
    }

    private void BuildFileChart(BitrateChartSnapshot snapshot)
    {
        var usePercent = snapshot.FileLengthBytes is > 0;
        var traces = new List<ITrace>();
        var allY = new List<double>();

        if (snapshot.ShowStreamOnChart && snapshot.FilePoints.Count > 0)
        {
            var xs = new List<double>(snapshot.FilePoints.Count);
            var totalYs = new List<double>(snapshot.FilePoints.Count);
            var usefulYs = new List<double>(snapshot.FilePoints.Count);

            foreach (var point in snapshot.FilePoints)
            {
                xs.Add(ToFileX(point.ByteOffset, snapshot.FileLengthBytes, usePercent));
                var totalMbps = point.TotalBitsPerSecond / 1_000_000d;
                var usefulMbps = point.UsefulBitsPerSecond / 1_000_000d;
                totalYs.Add(totalMbps);
                usefulYs.Add(usefulMbps);
                allY.Add(totalMbps);
                allY.Add(usefulMbps);
            }

            traces.Add(CreateLineTrace("Stream total", ToObjectList(xs), ToObjectList(totalYs), "#4682b4"));
            traces.Add(CreateLineTrace("Stream useful", ToObjectList(xs), ToObjectList(usefulYs), "#228b22"));
        }

        if (snapshot.ShowIndividualPidsOnChart)
            AddPidFileTraces(snapshot, usePercent, traces, allY);

        if (snapshot.ShowPidSumOnChart && snapshot.SumFilePoints.Count > 0)
        {
            var xs = new List<double>(snapshot.SumFilePoints.Count);
            var ys = new List<double>(snapshot.SumFilePoints.Count);
            foreach (var point in snapshot.SumFilePoints)
            {
                xs.Add(ToFileX(point.ByteOffset, snapshot.FileLengthBytes, usePercent));
                var mbps = point.BitsPerSecond / 1_000_000d;
                ys.Add(mbps);
                allY.Add(mbps);
            }

            traces.Add(CreateLineTrace("Selected sum", ToObjectList(xs), ToObjectList(ys), BitrateChartColors.SumLine, 3));
        }

        FinalizeChart(traces, allY, usePercent ? "File position (%)" : "File offset (MB)",
            usePercent ? "Bitrate vs file position" : "Bitrate vs byte offset");
    }

    private void BuildUdpChart(BitrateChartSnapshot snapshot)
    {
        var traces = new List<ITrace>();
        var allY = new List<double>();
        DateTime? origin = null;

        if (snapshot.ShowStreamOnChart && snapshot.UdpPoints.Count > 0)
        {
            origin ??= snapshot.UdpPoints[0].TimestampUtc;
            var xs = new List<double>(snapshot.UdpPoints.Count);
            var totalYs = new List<double>(snapshot.UdpPoints.Count);
            var usefulYs = new List<double>(snapshot.UdpPoints.Count);

            foreach (var point in snapshot.UdpPoints)
            {
                xs.Add((point.TimestampUtc - origin.Value).TotalSeconds);
                var totalMbps = point.TotalBitsPerSecond / 1_000_000d;
                var usefulMbps = point.UsefulBitsPerSecond / 1_000_000d;
                totalYs.Add(totalMbps);
                usefulYs.Add(usefulMbps);
                allY.Add(totalMbps);
                allY.Add(usefulMbps);
            }

            traces.Add(CreateLineTrace("Stream total", ToObjectList(xs), ToObjectList(totalYs), "#4682b4"));
            traces.Add(CreateLineTrace("Stream useful", ToObjectList(xs), ToObjectList(usefulYs), "#228b22"));
        }

        if (snapshot.ShowIndividualPidsOnChart)
            AddPidUdpTraces(snapshot, ref origin, traces, allY);

        if (snapshot.ShowPidSumOnChart && snapshot.SumUdpPoints.Count > 0)
        {
            origin ??= snapshot.SumUdpPoints[0].TimestampUtc;
            var xs = new List<double>(snapshot.SumUdpPoints.Count);
            var ys = new List<double>(snapshot.SumUdpPoints.Count);
            foreach (var point in snapshot.SumUdpPoints)
            {
                xs.Add((point.TimestampUtc - origin.Value).TotalSeconds);
                var mbps = point.BitsPerSecond / 1_000_000d;
                ys.Add(mbps);
                allY.Add(mbps);
            }

            traces.Add(CreateLineTrace("Selected sum", ToObjectList(xs), ToObjectList(ys), BitrateChartColors.SumLine, 3));
        }

        FinalizeChart(traces, allY, "Time (s)", "Live bitrate");
    }

    private void FinalizeChart(List<ITrace> traces, List<double> allY, string xLabel, string title)
    {
        if (traces.Count == 0)
        {
            _hasData = false;
            _data = [];
            return;
        }

        _data = traces;
        var xRange = ComputeXRangeFromTraces(traces);
        var yRange = ComputeYRange(allY);
        SetPlotRanges(xRange, yRange);
        _layout = CreateLayout(title, xLabel, "Mbps", xRange, yRange, FitRevision);
    }

    private static void AddPidFileTraces(
        BitrateChartSnapshot snapshot,
        bool usePercent,
        List<ITrace> traces,
        List<double> allY)
    {
        var index = 0;
        foreach (var pid in snapshot.ChartPids)
        {
            if (!snapshot.PidFilePoints.TryGetValue(pid, out var points) || points.Count == 0)
            {
                index++;
                continue;
            }

            var xs = new List<double>(points.Count);
            var ys = new List<double>(points.Count);
            foreach (var point in points)
            {
                xs.Add(ToFileX(point.ByteOffset, snapshot.FileLengthBytes, usePercent));
                var mbps = point.BitsPerSecond / 1_000_000d;
                ys.Add(mbps);
                allY.Add(mbps);
            }

            traces.Add(CreateLineTrace(
                $"PID 0x{pid:X4}",
                ToObjectList(xs),
                ToObjectList(ys),
                BitrateChartColors.ForIndex(index)));
            index++;
        }
    }

    private static void AddPidUdpTraces(
        BitrateChartSnapshot snapshot,
        ref DateTime? origin,
        List<ITrace> traces,
        List<double> allY)
    {
        var index = 0;
        foreach (var pid in snapshot.ChartPids)
        {
            if (!snapshot.PidUdpPoints.TryGetValue(pid, out var points) || points.Count == 0)
            {
                index++;
                continue;
            }

            origin ??= points[0].TimestampUtc;
            var xs = new List<double>(points.Count);
            var ys = new List<double>(points.Count);
            foreach (var point in points)
            {
                xs.Add((point.TimestampUtc - origin.Value).TotalSeconds);
                var mbps = point.BitsPerSecond / 1_000_000d;
                ys.Add(mbps);
                allY.Add(mbps);
            }

            traces.Add(CreateLineTrace(
                $"PID 0x{pid:X4}",
                ToObjectList(xs),
                ToObjectList(ys),
                BitrateChartColors.ForIndex(index)));
            index++;
        }
    }

    private static double ToFileX(long byteOffset, long? fileLengthBytes, bool usePercent) =>
        usePercent && fileLengthBytes is > 0
            ? 100d * byteOffset / fileLengthBytes.Value
            : byteOffset / 1_000_000d;

    private void SetPlotRanges((double Min, double Max) xRange, (double Min, double Max) yRange)
    {
        _xMin = xRange.Min;
        _xMax = xRange.Max;
        _yMin = yRange.Min;
        _yMax = yRange.Max;
    }

    private static Scatter CreateLineTrace(
        string name,
        IList<object> x,
        IList<object> y,
        string color,
        int width = 2) =>
        new()
        {
            Name = name,
            Mode = ModeFlag.Lines,
            X = x,
            Y = y,
            Line = new Line { Color = color, Width = width }
        };

    private static Layout CreateLayout(
        string title,
        string xLabel,
        string yLabel,
        (double Min, double Max) xRange,
        (double Min, double Max) yRange,
        int uiRevision) =>
        new()
        {
            Title = new Plotly.Blazor.LayoutLib.Title { Text = title },
            AutoSize = true,
            UiRevision = uiRevision.ToString(),
            Margin = new Margin { L = 56, R = 24, T = 48, B = 56 },
            XAxis = new List<XAxis>
            {
                new()
                {
                    Title = new Plotly.Blazor.LayoutLib.XAxisLib.Title { Text = xLabel },
                    ZeroLine = false,
                    Range = new List<object> { xRange.Min, xRange.Max }
                }
            },
            YAxis = new List<YAxis>
            {
                new()
                {
                    Title = new Plotly.Blazor.LayoutLib.YAxisLib.Title { Text = yLabel },
                    ZeroLine = false,
                    Range = new List<object> { yRange.Min, yRange.Max },
                    FixedRange = true
                }
            },
            Legend = new List<Legend>
            {
                new() { Orientation = Plotly.Blazor.LayoutLib.LegendLib.OrientationEnum.H }
            }
        };

    private static (double Min, double Max) ComputeXRangeFromTraces(IEnumerable<ITrace> traces)
    {
        var min = double.PositiveInfinity;
        var max = double.NegativeInfinity;

        foreach (var trace in traces)
        {
            if (trace is not Scatter scatter || scatter.X is null)
                continue;

            foreach (var xObj in scatter.X)
            {
                if (xObj is not double x)
                    continue;

                if (x < min) min = x;
                if (x > max) max = x;
            }
        }

        if (double.IsInfinity(min) || double.IsInfinity(max))
            return (0, 1);

        return ExpandAxisRange(min, max, XAxisPaddingRatio, MinXAxisPadding);
    }

    private static (double Min, double Max) ComputeYRange(IEnumerable<double> values)
    {
        var max = double.NegativeInfinity;

        foreach (var value in values)
        {
            if (value > max)
                max = value;
        }

        if (double.IsNegativeInfinity(max))
            return (0, 1);

        if (max <= 0)
            return (0, 1);

        var topPad = Math.Max(max * YAxisPaddingRatio, MinYAxisPaddingMbps);
        return (0, max + topPad);
    }

    private static (double Min, double Max) ExpandAxisRange(double min, double max, double paddingRatio, double minPadding)
    {
        if (Math.Abs(max - min) < 1e-9)
        {
            var pad = Math.Max(Math.Abs(max) * paddingRatio, minPadding);
            return (min - pad, max + pad);
        }

        var span = max - min;
        var margin = Math.Max(span * paddingRatio, minPadding);
        return (min - margin, max + margin);
    }

    private static List<object> ToObjectList(IReadOnlyList<double> values)
    {
        var result = new List<object>(values.Count);
        foreach (var value in values)
            result.Add(value);

        return result;
    }

    private static string BuildPlaceholderText(BitrateChartSnapshot snapshot, bool hasData)
    {
        if (hasData)
            return snapshot.Mode switch
            {
                BitrateChartMode.File => "Rendering bitrate chart…",
                BitrateChartMode.Udp => "Rendering live bitrate chart…",
                _ => ""
            };

        if (snapshot.Mode == BitrateChartMode.File)
        {
            if (snapshot.ShowPidSumOnChart && snapshot.ChartPids.Count >= 2 && !snapshot.HasPidSamples)
                return "No PID bitrate samples yet. Select PIDs in Bitrate… and restart the file (or wait for windows if parsing).";

            if (snapshot.HasStoredSamples)
                return "No data for the selected chart options. Enable Stream and/or Per-PID lines, or ensure at least two PIDs have samples for the sum.";

            return "Waiting for bitrate windows during file parse…";
        }

        if (snapshot.Mode == BitrateChartMode.Udp)
        {
            if (snapshot.ShowPidSumOnChart && snapshot.ChartPids.Count >= 2 && !snapshot.HasPidSamples)
                return "No PID bitrate samples yet. Select PIDs in Bitrate… and restart UDP play.";

            if (snapshot.HasStoredSamples)
                return "No data for the selected chart options.";

            return "Waiting for live bitrate samples…";
        }

        if (snapshot.ChartPids.Count > 0 || snapshot.ShowStreamOnChart)
            return "Open a file or start UDP to collect bitrate samples.";

        return "Open Bitrate… to choose stream and/or PID traces, then parse a file or UDP stream.";
    }

    private static string BuildChartTitle(BitrateChartSnapshot snapshot)
    {
        if (snapshot.ChartPids.Count == 0)
            return "Transport bitrate";

        return snapshot.ShowStreamOnChart
            ? "Transport and PID bitrate"
            : "PID bitrate";
    }

    private static string BuildStatsText(BitrateChartSnapshot snapshot)
    {
        var parts = new List<string>();

        if (snapshot.ShowStreamOnChart && snapshot.Mode == BitrateChartMode.File && snapshot.FilePoints.Count > 0)
        {
            var avgTotal = snapshot.AverageTotalMegabitsPerSecond;
            var avgUseful = snapshot.AverageUsefulMegabitsPerSecond;
            if (avgTotal.HasValue && avgUseful.HasValue)
                parts.Add($"Stream avg {avgTotal.Value:F2} / {avgUseful.Value:F2} Mbps");
        }

        if (snapshot.ShowStreamOnChart && snapshot.Mode == BitrateChartMode.Udp && snapshot.UdpPoints.Count > 0)
        {
            var latest = snapshot.UdpPoints[^1];
            parts.Add($"Stream {latest.TotalBitsPerSecond / 1_000_000d:F2} / {latest.UsefulBitsPerSecond / 1_000_000d:F2} Mbps");
        }

        if (snapshot.ChartPids.Count > 0)
        {
            var pidCount = snapshot.Mode switch
            {
                BitrateChartMode.File => snapshot.PidFilePoints.Count(kv => kv.Value.Count > 0),
                BitrateChartMode.Udp => snapshot.PidUdpPoints.Count(kv => kv.Value.Count > 0),
                _ => 0
            };
            parts.Add($"{pidCount}/{snapshot.ChartPids.Count} PID traces");
        }

        return parts.Count == 0 ? "" : string.Join(" · ", parts);
    }
}
